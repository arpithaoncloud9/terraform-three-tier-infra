# ============ Terraform ============
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
.terraform/
terraform.tfvars

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Plan output
*.tfplan

# Allow the example tfvars
!terraform.tfvars.example

# ============ Node.js / App ============
app/node_modules/
app/package-lock.json
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============ Docker ============
.docker
.dockerignore

# ============ IDE / Editor ============
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ============ Environment ============
.env
.env.local
.env.*.local
.env.production.local

# ============ OS ============
.DS_Store
.AppleDouble
.LSOverride
*.pem
*.key
*.crt

# ============ AWS ============
.aws/
credentials
~/.aws/

# ============ Build artifacts ============
dist/
build/
*.tar
*.tar.gz
*.zip

# Private keys - NEVER commit these!
*.pem
**/aws-3tier-dev-key.pem
modules/compute/aws-3tier-dev-key.pem

# Terraform state files
*.tfstate
*.tfstate.*
.terraform/